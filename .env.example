JUDGE_SERVER_URL=your_judge_server_url
JUDGE_SERVER_TOKEN=your_judge_server_token
JWT_SECRET=your_jwt_secret
DATABASE_URL=your_database_url
DATABASE_USERNAME=your_database_username
DATABASE_PASSWORD=your_database_password
JWT_ACCESS_TOKEN_EXPIRATION=your_jwt_access_token_expiration
JWT_REFRESH_TOKEN_EXPIRATION=your_jwt_refresh_token_expiration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Frontend origin the API sends the browser back to after login.
# Change this per environment (dev http://localhost:5173, docker http://localhost, prod https://your-domain).
APP_BASE_URL=http://localhost:5173
# Google redirect_uri points at THIS API (not the SPA). Register this exact URL in Google Console.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/outbound/google/callback
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URI=https://www.googleapis.com/oauth2/v3/userinfo